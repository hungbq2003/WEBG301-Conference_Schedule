{% extends "base.html.twig" %}

{% block title %}My Account - Conference Scheduler{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h3>My Account</h3>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <h5>Profile</h5>
                        <p><strong>Name:</strong> {{ user.fullName }}</p>
                        <p><strong>Email:</strong> {{ user.email }}</p>
                        <p><strong>Member since:</strong> {{ user.createdAt|date('F j, Y') }}</p>
                    </div>

                    <div class="d-flex gap-2">
                        <a href="{{ path('app_home') }}" class="btn btn-secondary">Back to Home</a>
                        <a href="{{ path('app_logout') }}" class="btn btn-danger">Logout</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

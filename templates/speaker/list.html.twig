{% extends "base.html.twig" %}

{% block title %}Speakers - Conference Scheduler{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>Speakers</h1>
            <p class="text-muted">Manage the speaker roster for your conferences.</p>
        </div>
        <a href="{{ path('app_speaker_new') }}" class="btn btn-primary">Add Speaker</a>
    </div>

    {% if speakers %}
        <div class="row gy-4">
            {% for speaker in speakers %}
                <div class="col-md-6">
                    <div class="card speaker-card">
                        <div class="card-body">
                            <h5 class="speaker-name">{{ speaker.fullName }}</h5>
                            <p class="speaker-affiliation">{{ speaker.affiliation }}</p>
                            <p class="speaker-email">{{ speaker.email }}</p>
                            <div class="mt-3">
                                <a href="{{ path('app_speaker_show', {id: speaker.id}) }}" class="btn btn-primary btn-sm">View</a>
                                <a href="{{ path('app_speaker_edit', {id: speaker.id}) }}" class="btn btn-secondary btn-sm">Edit</a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="alert alert-info">No speakers available yet.</div>
    {% endif %}
</div>
{% endblock %}

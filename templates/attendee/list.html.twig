{% extends "base.html.twig" %}

{% block title %}Attendees - Conference Scheduler{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>Attendee Directory</h1>
            <p class="text-muted">Browse all registered attendees for conferences.</p>
        </div>
        <a href="{{ path('app_home') }}" class="btn btn-secondary">Back to Home</a>
    </div>

    {% if attendees %}
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Company</th>
                    <th>Conference</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for attendee in attendees %}
                    <tr>
                        <td>{{ attendee.fullName }}</td>
                        <td>{{ attendee.email }}</td>
                        <td>{{ attendee.company }}</td>
                        <td>{{ attendee.conference.name }}</td>
                        <td>
                            {% if attendee.isCheckedIn %}
                                <span class="badge badge-success">Checked In</span>
                            {% else %}
                                <span class="badge badge-warning">Pending</span>
                            {% endif %}
                        </td>
                        <td><a href="{{ path('app_attendee_show', {id: attendee.id}) }}" class="btn btn-sm btn-primary">View</a></td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <div class="alert alert-info">No attendees are registered yet.</div>
    {% endif %}
</div>
{% endblock %}

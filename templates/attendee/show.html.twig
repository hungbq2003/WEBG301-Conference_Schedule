{% extends "base.html.twig" %}

{% block title %}{{ attendee.fullName }} - Conference Scheduler{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h3>{{ attendee.fullName }}</h3>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <p><strong>Email:</strong> {{ attendee.email }}</p>
                            <p><strong>Phone:</strong> {{ attendee.phone ?: 'N/A' }}</p>
                            <p><strong>Company:</strong> {{ attendee.company }}</p>
                            <p><strong>Job Title:</strong> {{ attendee.jobTitle }}</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Ticket Type:</strong> {{ attendee.ticketType }}</p>
                            <p><strong>Conference:</strong> {{ attendee.conference.name }}</p>
                            <p><strong>Registered:</strong> {{ attendee.registeredAt|date('M d, Y') }}</p>
                            <p>
                                <strong>Status:</strong>
                                {% if attendee.isCheckedIn %}
                                    <span class="badge badge-success">Checked In</span>
                                {% else %}
                                    <span class="badge badge-warning">Pending</span>
                                {% endif %}
                            </p>
                        </div>
                    </div>
                    <div>
                        <h5>Sessions Registered</h5>
                        {% if attendee.sessions|length > 0 %}
                            <ul>
                                {% for session in attendee.sessions %}
                                    <li>{{ session.title }} ({{ session.room }})</li>
                                {% endfor %}
                            </ul>
                        {% else %}
                            <p class="text-muted">This attendee is not registered for any sessions yet.</p>
                        {% endif %}
                    </div>
                    <div class="d-flex gap-2 flex-wrap mt-3">
                        <a href="{{ path('app_attendees_list') }}" class="btn btn-secondary">Back to Attendees</a>
                        <a href="{{ path('app_attendee_edit', {id: attendee.id}) }}" class="btn btn-primary">Edit</a>
                        {% if is_granted('ROLE_ADMIN') %}
                            <form action="{{ path('app_attendee_delete', {id: attendee.id}) }}" method="post" class="m-0">
                                <button type="submit" class="btn btn-danger" onclick="return confirm('Delete this attendee?');">Delete Attendee</button>
                            </form>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

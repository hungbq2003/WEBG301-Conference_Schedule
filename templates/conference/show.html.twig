{% extends "base.html.twig" %}

{% block title %}{{ conference.name }} - Conference Scheduler{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row mb-4">
        <div class="col-lg-8">
            <h1>{{ conference.name }}</h1>
            <p class="text-muted">{{ conference.location }} | {{ conference.startDate|date('M d, Y') }} - {{ conference.endDate|date('M d, Y') }}</p>
            <div class="card mb-4">
                <div class="card-body">
                    <h4>Description</h4>
                    <p>{{ conference.description }}</p>
                </div>
            </div>
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="card bg-light p-3">
                        <h5>Sessions</h5>
                        <p class="display-6 mb-0">{{ sessions|length }}</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-light p-3">
                        <h5>Speakers</h5>
                        <p class="display-6 mb-0">{{ speakers|length }}</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-light p-3">
                        <h5>Attendees</h5>
                        <p class="display-6 mb-0">{{ attendee_count }}</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5>Conference Details</h5>
                    <ul class="list-unstyled mb-0">
                        <li><strong>Location:</strong> {{ conference.location }}</li>
                        <li><strong>Capacity:</strong> {{ conference.capacity }}</li>
                        <li><strong>Created At:</strong> {{ conference.createdAt|date('M d, Y') }}</li>
                    </ul>
                </div>
            </div>
            <div class="card shadow-sm mt-4">
                <div class="card-body">
                    <h5>Actions</h5>
                    <a href="{{ path('app_conference_schedule', {id: conference.id}) }}" class="btn btn-primary w-100 mb-2">View Schedule</a>
                    <a href="{{ path('app_conference_speakers', {id: conference.id}) }}" class="btn btn-secondary w-100 mb-2">View Speakers</a>
                    <a href="{{ path('app_attendees_by_conference', {conferenceId: conference.id}) }}" class="btn btn-success w-100 mb-2">Attendees</a>
                    <a href="{{ path('app_attendee_register', {conferenceId: conference.id}) }}" class="btn btn-info w-100 mb-2">
                        Register Attendee{% if not app.user %} <small class="d-block text-white-50">(login required)</small>{% endif %}
                    </a>
                    <a href="{{ path('app_conference_edit', {id: conference.id}) }}" class="btn btn-outline-primary w-100 mb-2">Edit Conference</a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <form action="{{ path('app_conference_delete', {id: conference.id}) }}" method="post" class="m-0">
                            <button type="submit" class="btn btn-danger w-100" onclick="return confirm('Delete this conference?');">Delete Conference</button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5>Sessions</h5>
                </div>
                <div class="card-body">
                    {% if sessions %}
                        <ul class="list-group list-group-flush">
                            {% for session in sessions|slice(0, 4) %}
                                <li class="list-group-item">
                                    <a href="{{ path('app_session_show', {id: session.id}) }}"><strong>{{ session.title }}</strong></a>
                                    <p class="mb-1 text-muted">{{ session.room }} &mdash; {{ session.track }}</p>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <div class="alert alert-warning">No sessions defined yet.</div>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-lg-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5>Speakers</h5>
                </div>
                <div class="card-body">
                    {% if speakers %}
                        <ul class="list-group list-group-flush">
                            {% for speaker in speakers|slice(0, 4) %}
                                <li class="list-group-item">
                                    <strong>{{ speaker.fullName }}</strong><br>
                                    <small class="text-muted">{{ speaker.affiliation }}</small>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <div class="alert alert-warning">No speakers registered yet.</div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

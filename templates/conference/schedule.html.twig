{% extends "base.html.twig" %}

{% block title %}Schedule - {{ conference.name }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>{{ conference.name }} Schedule</h1>
            <p class="text-muted">Review session dates, rooms, and speaker availability.</p>
        </div>
        <a href="{{ path('app_conference_show', {id: conference.id}) }}" class="btn btn-secondary">Back to Conference</a>
    </div>

    {% if sessions %}
        <div class="row gy-4">
            {% for session in sessions %}
                <div class="col-lg-6">
                    <div class="card session-card">
                        <div class="card-body">
                            <div class="time-slot">{{ session.startTime|date('h:i A') }} - {{ session.endTime|date('h:i A') }}</div>
                            <h5 class="card-title">{{ session.title }}</h5>
                            <p class="card-text">{{ session.description|slice(0, 140) }}...</p>
                            <div class="room mb-2">Room: {{ session.room }}</div>
                            <div class="track-badge">{{ session.track }}</div>
                            <div class="mt-3">
                                <a href="{{ path('app_session_show', {id: session.id}) }}" class="btn btn-primary btn-sm">View Session</a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="alert alert-info">No sessions are scheduled for this conference yet.</div>
    {% endif %}
</div>
{% endblock %}

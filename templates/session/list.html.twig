{% extends "base.html.twig" %}

{% block title %}Sessions - Conference Scheduler{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>All Sessions</h1>
            <p class="text-muted">Browse session details and find the talks that best match your goals.</p>
        </div>
        <a href="{{ path('app_home') }}" class="btn btn-secondary">Back to Home</a>
    </div>

    {% if sessions %}
        <div class="row gy-4">
            {% for session in sessions %}
                <div class="col-lg-6">
                    <div class="card session-card">
                        <div class="card-body">
                            <div class="time-slot">{{ session.startTime|date('M d, Y h:i A') }}</div>
                            <h5>{{ session.title }}</h5>
                            <p>{{ session.description|slice(0, 120) }}...</p>
                            <p class="mb-1"><strong>Room:</strong> {{ session.room }}</p>
                            <p class="mb-1"><strong>Track:</strong> {{ session.track }}</p>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <a href="{{ path('app_session_show', {id: session.id}) }}" class="btn btn-primary btn-sm">View Details</a>
                                <span class="badge badge-primary">{{ session.attendees|length }} registered</span>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="alert alert-info">No sessions available at the moment.</div>
    {% endif %}
</div>
{% endblock %}
